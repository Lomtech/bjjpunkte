# ─────────────────────────────────────────────────────────────────────────────
# Osss / bjjpunkte — .env Vorlage
# ─────────────────────────────────────────────────────────────────────────────
# Kopiere diese Datei zu `.env.local` und fülle die echten Werte ein.
# .env-Files sind via .gitignore vom Repo ausgeschlossen.
#
# Audit 2026-05-11: ANALYTICS_SALT, IBAN_ENCRYPTION_KEY und CRON_SECRET
# dürfen in Production NIE leer/Default sein — sonst bricht das DSGVO-
# Anonymisierungsversprechen bzw. der Encryption-/Auth-Schutz.

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOURPROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...           # server-only, NIE NEXT_PUBLIC_

# ─── App-URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000          # Production: https://www.osss.pro

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...                    # Platform-Webhook
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...            # Connect-Webhook (Account events)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PLATFORM_FEE_PERCENT=0                      # Anteil platform-fee (0 = USP vs. MAAT)

# Lifetime-Pilot-Coupon (Stripe Dashboard verwaltet — hier nur Dokumentation)
# STRIPE_LIFETIME_PILOT_COUPON=PILOT10             # 40% Rabatt forever, max 10 Slots

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Osss <no-reply@osss.pro>

# ─── Rate-Limit + Cache (Upstash Redis) ──────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://YOUR.upstash.io
UPSTASH_REDIS_REST_TOKEN=AY...

# ─── Encryption + Secrets ────────────────────────────────────────────────────
# AES-256-GCM Key für members.bank_iban_enc — 64 Hex-Zeichen.
# Erzeugen: `openssl rand -hex 32`
IBAN_ENCRYPTION_KEY=                                # KRITISCH

# HMAC für OAuth state-Tokens (Stripe Connect Callback)
OAUTH_STATE_SECRET=                                 # min 32 Zeichen

# CRON_SECRET: Bearer-Token für /api/cron/* — min 16 Zeichen.
# Erzeugen: `openssl rand -base64 32`
CRON_SECRET=                                        # KRITISCH

# Analytics-Salt: täglich rotierender Hash-Salt für page_views.visitor_hash.
# Erzeugen: `openssl rand -base64 48`
# OHNE diesen ist die Hash-Anonymisierung in Production reversibel — DSGVO-Verstoß.
ANALYTICS_SALT=                                     # KRITISCH

# Optional: detailliertes Health-Check-Diagnose-Token (Header X-Health-Debug-Token)
HEALTH_DEBUG_TOKEN=                                 # leer = keine Diagnose

# ─── Admin-CRM ───────────────────────────────────────────────────────────────
ADMIN_EMAILS=                                       # komma-separiert, z.B. you@osss.pro,co@osss.pro

# ─── CSRF Origin-Allowlist (optional, komma-separiert) ───────────────────────
# CSRF_ALLOWED_ORIGINS=https://custom-domain.example

# ─── Sentry ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://YOUR@sentry.io/PROJECT
# SENTRY_AUTH_TOKEN für Source-Map-Upload — nur in CI
SENTRY_AUTH_TOKEN=

# ─── Google Places (Lead-Enrichment, optional) ───────────────────────────────
GOOGLE_PLACES_API_KEY=

# ─── Smoke-Tests (optional, nur lokal) ───────────────────────────────────────
TEST_API_BASE=http://localhost:3000
TEST_OWNER_EMAIL=
TEST_OWNER_PASSWORD=
TEST_MEMBER_ID=
TEST_GYM_SLUG=
TEST_CRON_SECRET=
TEST_INACTIVE_PORTAL_TOKEN=
TEST_CRON_TRIGGER_ALLOWED=0                         # auf 1 setzen erlaubt cron-Trigger-Tests
